@model Carvisto.Models.Trip
<h2>Создать путешествие</h2>
<!-- Добавляем отображение ошибок валидации -->
<div asp-validation-summary="All" style="color: red;"></div>
<form asp-action="Create" method="post">
    <div>
        <label asp-for="From">Откуда</label>
        <input asp-for="From" />
        <span asp-validation-for="From" style="color: red;"></span>
    </div>
    <div>
        <label asp-for="To">Куда</label>
        <input asp-for="To" />
        <span asp-validation-for="To" style="color: red;"></span>
    </div>
    <div>
        <label asp-for="DepartureDate">Дата отправления</label>
        <input asp-for="DepartureDate" type="date" />
        <span asp-validation-for="DepartureDate" style="color: red;"></span>
    </div>
    <div>
        <label asp-for="Price">Цена</label>
        <input asp-for="Price" type="number" step="0.01" />
        <span asp-validation-for="Price" style="color: red;"></span>
    </div>
    <button type="submit">Создать</button>
</form>