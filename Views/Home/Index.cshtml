<h1>Добро пожаловать!</h1>
@if (User.Identity.IsAuthenticated)
{
    <p>Привет, @User.Identity.Name!</p>
    <p><a asp-controller="Trips" asp-action="Create">Создать путешествие</a></p>
    <p><a asp-controller="Trips" asp-action="Index">Найти путешествие</a></p>
    <form asp-controller="Account" asp-action="Logout" method="post">
        <button type="submit">Выйти</button>
    </form>
}
else
{
    <p><a asp-controller="Account" asp-action="Register">Регистрация</a></p>
    <p><a asp-controller="Account" asp-action="Login">Вход</a></p>
}